{
    "name": "zencode",
    "publisher": "SairajDev",
    "displayName": "ZenCode",
    "description": "A wellness-focused coding companion that tracks cognitive load, provides wellness insights, and promotes healthy coding habits",
    "version": "1.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/Sairaj-creator/zencode.git"
    },
    "icon": "logo.png",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "productivity",
        "health",
        "analytics",
        "typing",
        "wakatime alternative"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "zencode.showStats",
                "title": "ZenCode: Show Current Stats"
            },
            {
                "command": "zencode.openDashboard",
                "title": "ZenCode: Open Wellness Dashboard"
            }
        ],
        "configuration": {
            "title": "ZenCode",
            "properties": {
                "zencode.fatigueThreshold": {
                    "type": "number",
                    "default": 20,
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Fatigue threshold percentage (above which fatigue warnings appear)"
                },
                "zencode.strictMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable strict mode that shows modal warnings when fatigue is detected"
                },
                "zencode.autoZenMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically enable Zen Mode when high fatigue is detected"
                },
                "zencode.postureReminderInterval": {
                    "type": "number",
                    "default": 60,
                    "minimum": 0,
                    "description": "Posture reminder interval in minutes (set to 0 to disable)"
                },
                "zencode.smartBreakDuration": {
                    "type": "number",
                    "default": 42,
                    "minimum": 1,
                    "maximum": 120,
                    "description": "Continuous work duration in minutes before suggesting a break"
                },
                "zencode.wellnessNotifications": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable wellness notifications like hydration reminders"
                },
                "zencode.hydrationInterval": {
                    "type": "number",
                    "default": 30,
                    "minimum": 0,
                    "description": "Hydration reminder interval in minutes (set to 0 to disable)"
                },
                "zencode.eyeExerciseInterval": {
                    "type": "number",
                    "default": 20,
                    "minimum": 0,
                    "description": "Eye exercise reminder interval in minutes (set to 0 to disable)"
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "typescript": "^4.9.4"
    },
    "dependencies": {
        "vscode": "^1.1.38"
    }
}
