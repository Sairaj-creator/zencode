{
  "name": "zencode",
  "publisher": "SairajDev",
  "displayName": "ZenCode",
  "description": "Anti-burnout coding assistant",
  "version": "0.2.0",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "productivity",
    "health",
    "analytics",
    "typing",
    "wakatime alternative"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zencode.showStats",
        "title": "ZenCode: Show Quick Stats"
      },
      {
        "command": "zencode.openDashboard",
        "title": "ZenCode: Open Stress Dashboard"
      }
    ],
    "configuration": {
      "title": "ZenCode",
      "properties": {
        "zencode.fatigueThreshold": {
          "type": "number",
          "default": 20,
          "description": "Error rate percentage (0-100) that triggers a fatigue warning."
        },
        "zencode.strictMode": {
          "type": "boolean",
          "default": false,
          "description": "If true, enforces a break when stress is high."
        },
        "zencode.autoZenMode": {
          "type": "boolean",
          "default": false,
          "description": "If true, automatically toggles VS Code Zen Mode when stress exceeds the threshold."
        },
        "zencode.postureReminderInterval": {
          "type": "number",
          "default": 60,
          "description": "Interval in minutes for posture reminders. Set to 0 to disable."
        },
        "zencode.smartBreakDuration": {
          "type": "number",
          "default": 42,
          "description": "Duration in minutes of continuous work before suggesting a break."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
